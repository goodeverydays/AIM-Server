# GoImageServer 配置示例（复制为 .env 并按需修改；.env 已被 .gitignore 忽略）
# 程序启动时会自动加载 .env（当前目录或可执行文件目录），系统真实环境变量优先。

# ── 服务监听 ──
AVATAR_HOST=0.0.0.0
AVATAR_GRPC_PORT=19529
AVATAR_HTTP_PORT=8080
# 对外可访问地址（拼接头像URL用）。本地后端必填为真实IP/域名；对象存储模式可忽略。
AVATAR_PUBLIC_HOST=192.168.100.128
AVATAR_MAX_SIZE_MB=5

# ── 存储后端：local(本地文件) | s3(对象存储) ──
STORAGE_BACKEND=local

# 本地后端：建议设为【绝对持久路径】，避免从不同工作目录启动导致头像丢失。
# 相对路径会基于可执行文件所在目录解析（仍建议用绝对路径 + 独立数据盘）。
AVATAR_DIR=/var/lib/imavatar/avatars

# ── 对象存储后端（STORAGE_BACKEND=s3 时生效；需用 `go build -tags s3` 构建）──
# 兼容 阿里云OSS / 腾讯云COS / AWS S3 / MinIO，只换 endpoint 与凭证即可。
# 阿里云OSS 示例：
#   S3_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
#   S3_PUBLIC_BASE_URL=https://<bucket>.oss-cn-hangzhou.aliyuncs.com   # 或绑定的CDN域名
# 腾讯云COS 示例：
#   S3_ENDPOINT=cos.ap-guangzhou.myqcloud.com
# MinIO 自建示例：
#   S3_ENDPOINT=minio.example.com:9000
#   S3_USE_SSL=false
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=
S3_USE_SSL=true
# 公网/CDN 访问前缀；留空则回退为 https://<endpoint>/<bucket>（要求桶公共读）。
S3_PUBLIC_BASE_URL=
