# 复制为 .env 并填入真实值（.env 已被 gitignore，不会提交）
# LLM 配置：OpenAI 兼容接口，按厂商改 BASE_URL/MODEL 即可

LLM_PROVIDER=openai
OPENAI_API_KEY=sk-你的密钥
# DeepSeek:   https://api.deepseek.com/v1   模型 deepseek-chat
# Kimi:       https://api.moonshot.cn/v1    模型 moonshot-v1-8k
# 智谱:       https://open.bigmodel.cn/api/paas/v4   模型 glm-4-flash
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# 可选：限流配额
# AGENT_FREE_DAILY=5
# AGENT_VIP_DAILY=100
# AGENT_VIP_USERS=1001,1002

# 可选：Redis（不填用默认/内存降级）
# REDIS_ADDR=127.0.0.1:6379

# ============================================================
# 可选：RAG 记忆问答（skill=rag_qa）。默认关闭。
# 启用后，AI 助手能基于用户的历史聊天记录(向量检索)回答“我们上次聊的X是啥”这类问题。
# ============================================================
# RAG_ENABLED=1
# 读 t_chatmsg 的 MySQL DSN（与 IMServer 同库）：
# RAG_MYSQL_DSN=imuser:你的密码@tcp(127.0.0.1:3306)/imdb?charset=utf8mb4&parseTime=true
# embedding 提供商（OpenAI 兼容 /embeddings，与对话 LLM 解耦；DeepSeek 无 embedding）：
#   推荐 硅基流动(国内直连、免费 bge-m3):  BASE_URL=https://api.siliconflow.cn/v1  MODEL=BAAI/bge-m3
#   本地离线 Ollama:                       BASE_URL=http://localhost:11434/v1     MODEL=bge-m3
#   OpenAI:                                BASE_URL=https://api.openai.com/v1     MODEL=text-embedding-3-small
# EMBED_API_KEY=sk-你的embedding密钥
# EMBED_BASE_URL=https://api.siliconflow.cn/v1
# EMBED_MODEL=BAAI/bge-m3
# 可选检索参数：
# RAG_TOPK=8
# RAG_MAX_CORPUS=1000
# 向量库后端：memory(默认，进程内，零依赖) 或 qdrant(外部向量数据库)
# RAG_VECTOR_BACKEND=qdrant
# Qdrant(先 docker compose up -d qdrant 启动)：
# QDRANT_URL=http://localhost:6333
# QDRANT_COLLECTION=im_chat_rag
# QDRANT_API_KEY=            # 本地一般无需，云上 Qdrant 才填
