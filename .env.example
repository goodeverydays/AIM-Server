# 复制为 .env 填真实值(.env 勿提交)。docker compose 会自动读取同目录 .env。

# 阿里云 ECS 公网IP(或域名)——客户端连接 & 头像/媒体URL 用
PUBLIC_HOST=1.2.3.4

# MySQL(容器内自建,仅本机可达)
MYSQL_PASSWORD=改成强密码
MYSQL_DB=myim

# DeepSeek(对话 LLM)
DEEPSEEK_API_KEY=sk-你的deepseek密钥

# Embedding(RAG 记忆问答,推荐硅基流动免费 bge-m3)
EMBED_API_KEY=sk-你的硅基流动密钥
EMBED_BASE_URL=https://api.siliconflow.cn/v1
EMBED_MODEL=BAAI/bge-m3

# SMTP(邮箱验证码,以 QQ 邮箱为例)
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USERNAME=你的邮箱@qq.com
SMTP_PASSWORD=邮箱SMTP授权码
SMTP_FROM=你的邮箱@qq.com
