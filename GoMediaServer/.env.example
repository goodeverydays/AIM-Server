# GoMediaServer 配置示例（复制为 .env；.env 已被 .gitignore 忽略）
# 聊天媒体(语音/视频/图片/文件)存储服务。客户端经 HTTP 直传，避免大文件经 IMServer。

# ── 服务监听 ──
MEDIA_HOST=0.0.0.0
MEDIA_PORT=8090
MEDIA_PUBLIC_HOST=192.168.100.128      # 对外可访问地址(拼接媒体URL)
MEDIA_MAX_SIZE_MB=50                    # 单文件上限(视频可调大)

# ── 存储后端：local(本地文件) | s3(对象存储) ──
STORAGE_BACKEND=local
# 本地后端建议绝对持久路径(独立数据盘)，避免重启/重部署丢失
MEDIA_DIR=/var/lib/immedia/media

# ── 对象存储(STORAGE_BACKEND=s3，需 `go build -tags s3`)──
# 兼容 阿里云OSS / 腾讯云COS / AWS S3 / MinIO
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=
S3_USE_SSL=true
S3_PUBLIC_BASE_URL=
